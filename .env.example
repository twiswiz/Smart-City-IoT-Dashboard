PORT=4000
CLIENT_ORIGIN=http://localhost:5173
MONGODB_URI=mongodb://127.0.0.1:27017/smart_city_iot
DATA_SOURCE=simulator
DATASET_PATH=server/data/readings.csv
DATASET_REPLAY_INTERVAL_MS=5000
DATASET_LOOP=true
MQTT_BROKER_URL=mqtt://test.mosquitto.org
MQTT_TOPIC=smart-city-iot-dashboard/readings
SIMULATION_INTERVAL_MS=15000
SEED_HISTORY_DAYS=7
SEED_HISTORY_STEP_MINUTES=10
# Set SEED_HISTORY_FORCE=true to wipe and rebuild history on next boot.
SEED_HISTORY_FORCE=false
